# Copy to tools/.env (gitignored) and fill in ONE key.
#
# RECOMMENDED for recognizable Pokémon (open FLUX Kontext — NO IP filter):
REPLICATE_API_TOKEN=
# FAL_KEY=
#
# Closed models (work, but block recognizable-Pokémon ACTION poses via IP moderation):
# OPENAI_API_KEY=
# GEMINI_API_KEY=
#
# Optional overrides:
# IMAGE_PROVIDER=replicate            # force a provider when several keys are set
# REPLICATE_MODEL=black-forest-labs/flux-kontext-dev
# FAL_MODEL=fal-ai/flux-kontext/dev
